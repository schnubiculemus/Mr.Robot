[Unit]
Description=SchnuBot.ai WhatsApp Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/whatsapp-bot
ExecStart=/opt/whatsapp-bot/venv/bin/gunicorn \
    --bind 0.0.0.0:5000 \
    --workers 1 \
    --threads 4 \
    --timeout 120 \
    --keep-alive 5 \
    app:app
Restart=always
RestartSec=5
EnvironmentFile=/opt/whatsapp-bot/.env

[Install]
WantedBy=multi-user.target
